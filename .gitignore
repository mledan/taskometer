# dependencies
/node_modules
/.pnp
.pnp.js

# Terraform / Terragrunt — state, plans, and the .terragrunt-cache
# subdirectory each leaf creates on first init. Never commit these;
# state lives in the Azure backend, plans are ephemeral.
**/.terraform/
**/.terragrunt-cache/
**/terraform.tfstate
**/terraform.tfstate.backup
**/.terraform.lock.hcl
**/plan.txt
*.tfvars
!**/*.example.tfvars

# testing
/coverage

# production
/build
dist

# cache
.electron-vendors.cache.json

# misc
.DS_Store

# Environment variables - NEVER commit these!
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.me
.env.keys

# Google OAuth Client Secrets - NEVER commit!
client_secret*.json
credentials.json
token.json

# Keep these for documentation
!.env.example
!.env.vault

npm-debug.log*
yarn-debug.log*
yarn-error.log*

.env*
.flaskenv*
!.env.project
.vercel
