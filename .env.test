# Vitest mode env. Vite loads .env.test in preference to .env.local
# when NODE_ENV=test (vitest). We explicitly clear Clerk's publishable
# key so CLERK_ENABLED is false in unit tests — keeps the legacy
# code paths exercised and stops jsdom from trying to open Clerk
# modals it can't actually mount.
#
# Production tests (curl against the deploy) hit the real env, so
# this only affects in-process React tests.
VITE_CLERK_PUBLISHABLE_KEY=
