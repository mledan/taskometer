{
  "framework": "vite",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!api|assets|favicon\\.ico|manifest\\.json|robots\\.txt|logo128\\.png).*)", "destination": "/index.html" }
  ]
}
